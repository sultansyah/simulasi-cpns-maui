<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="SimulasiCPNS.Views.QuestionPage"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False"
    BackgroundColor="#F8FAFC">

    <Grid RowDefinitions="Auto,*">

        <!-- HEADER -->
        <Border
            Grid.Row="0"
            BackgroundColor="{StaticResource Primary}"
            StrokeThickness="0"
            Padding="20,30,20,24">

            <Grid
                RowDefinitions="Auto,Auto"
                RowSpacing="12">

                <Grid ColumnDefinitions="Auto,*">

                    <Label
                        Text="←"
                        FontSize="22"
                        TextColor="White"
                        VerticalTextAlignment="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackTapped" />
                        </Label.GestureRecognizers>
                    </Label>

                    <VerticalStackLayout
                        Grid.Column="1"
                        Margin="12,0,0,0"
                        Spacing="2">

                        <Label
                            x:Name="TitlePage"
                            Text=""
                            FontSize="20"
                            FontAttributes="Bold"
                            TextColor="White" />

                        <Label
                            x:Name="DescriptionPage"
                            Text=""
                            FontSize="13"
                            TextColor="#FFE4E6" />

                    </VerticalStackLayout>

                </Grid>

            </Grid>

        </Border>

        <!-- CONTENT -->
        <Border
            Grid.Row="1"
            Margin="0,-16,0,0"
            BackgroundColor="#F8FAFC"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 24,24,0,0">

            <Grid
                Padding="16"
                RowDefinitions="Auto,*,Auto"
                RowSpacing="16">

                <!-- FILTER -->
                <ScrollView
                    Orientation="Horizontal"
                    HorizontalScrollBarVisibility="Never">

                    <HorizontalStackLayout 
                        Spacing="8"
                        x:Name="SubCategoryListLayout"
                        BindableLayout.ItemsSource="{Binding}">

                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    x:Name="SubCategoryBorder"
                                    BackgroundColor="{Binding BackgroundColor}"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 999"
                                    Padding="14,8">

                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnSubCategoryTapped" />
                                    </Border.GestureRecognizers>

                                    <Label
                                        x:Name="SubCategoryLabel"
                                        Text="{Binding SubCategory}"
                                        FontSize="12"
                                        FontAttributes="Bold"
                                        TextColor="{Binding TextColor}" />

                                </Border>
                            </DataTemplate>

                        </BindableLayout.ItemTemplate>

                    </HorizontalStackLayout>

                </ScrollView>

                <!-- LIST SOAL -->
                <CollectionView 
                    Grid.Row="1"
                    x:Name="QuestionListLayout"
                    ItemsSource="{Binding}">

                    <CollectionView.ItemTemplate>

                        <DataTemplate>

                            <Border
                                Margin="0,0,0,10"
                                BackgroundColor="White"
                                Stroke="#E5E7EB"
                                StrokeShape="RoundRectangle 14"
                                Padding="12">

                                <Grid
                                    ColumnDefinitions="Auto,*,Auto"
                                    ColumnSpacing="12">

                                    <!-- NOMOR -->
                                    <Border
                                        WidthRequest="30"
                                        HeightRequest="30"
                                        BackgroundColor="{StaticResource Primary}"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 8">

                                        <Label
                                            Text="{Binding DisplayNumber}"
                                            FontSize="12"
                                            FontAttributes="Bold"
                                            TextColor="White"
                                            HorizontalTextAlignment="Center"
                                            VerticalTextAlignment="Center" />

                                    </Border>

                                    <!-- INFO -->
                                    <VerticalStackLayout
                                        Grid.Column="1"
                                        Spacing="2"
                                        VerticalOptions="Center">

                                        <Label
                                            Text="{Binding QuestionText}"
                                            FontSize="14"
                                            FontAttributes="Bold"
                                            TextColor="#111827"
                                            MaxLines="1"
                                            LineBreakMode="TailTruncation" />

                                        <Border
                                            BackgroundColor="Green"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 999"
                                            Padding="8,3"
                                            HorizontalOptions="Start">

                                            <Label
                                                Text="{Binding DifficultyDisplay}"
                                                FontSize="11"
                                                FontAttributes="Bold"
                                                TextColor="White" />

                                        </Border>

                                    </VerticalStackLayout>

                                    <!-- BOOKMARK -->
                                    <Grid
                                        Grid.Column="2"
                                        WidthRequest="28"
                                        HeightRequest="28"
                                        VerticalOptions="Center"
                                        HorizontalOptions="Center">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnBookmarkTapped" />
                                        </Grid.GestureRecognizers>

                                        <Image
                                            Source="icon_star_empty.svg"
                                            WidthRequest="22"
                                            HeightRequest="22"
                                            Aspect="AspectFit"
                                            VerticalOptions="Center"
                                            HorizontalOptions="Center"
                                            IsVisible="{Binding IsBookmarked, Converter={StaticResource InverseBoolConverter}}" />

                                        <Image
                                            Source="icon_star_filled.svg"
                                            WidthRequest="22"
                                            HeightRequest="22"
                                            Aspect="AspectFit"
                                            VerticalOptions="Center"
                                            HorizontalOptions="Center"
                                            IsVisible="{Binding IsBookmarked}" />
                                    </Grid>

                                </Grid>

                            </Border>

                        </DataTemplate>

                    </CollectionView.ItemTemplate>

                </CollectionView>

                <!-- BUTTON -->
                <Button
                    Grid.Row="2"
                    HeightRequest="52"
                    CornerRadius="12"
                    BackgroundColor="{StaticResource Primary}"
                    Text="Kerjakan Semua Soal (20)"
                    FontAttributes="Bold"
                    TextColor="White" />

            </Grid>

        </Border>

    </Grid>

</ContentPage>