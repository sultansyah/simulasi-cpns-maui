<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SimulasiCPNS.Views.OnboardingPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    NavigationPage.HasNavigationBar="False"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False"
    BackgroundColor="#FFFFFF">

    <ScrollView>
        <Grid
            RowDefinitions="*"
            BackgroundColor="#FFFFFF">

            <Border
                BackgroundColor="White"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 0"
                Padding="24,46,24,28"
                HorizontalOptions="Fill"
                VerticalOptions="Fill">

                <VerticalStackLayout Spacing="22">

                    <!-- Header -->
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Spacing="8">
                            <Label
                                Text="Selamat Datang!"
                                FontSize="24"
                                FontAttributes="Bold"
                                TextColor="#047857" />

                            <Label
                                Text="Sebelum mulai, lengkapi&#10;data dirimu terlebih dahulu."
                                FontSize="15"
                                LineHeight="1.2"
                                TextColor="#374151" />
                        </VerticalStackLayout>

                        <Grid
                            Grid.Column="1"
                            WidthRequest="110"
                            HeightRequest="110">

                            <Ellipse
                                Fill="#E8F7EF"
                                WidthRequest="96"
                                HeightRequest="96"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />

                            <Border
                                WidthRequest="58"
                                HeightRequest="76"
                                BackgroundColor="#2FBF71"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 8"
                                Rotation="5"
                                HorizontalOptions="Center"
                                VerticalOptions="Center">

                                <VerticalStackLayout
                                    Padding="10,16"
                                    Spacing="8">
                                    <BoxView
                                        HeightRequest="4"
                                        CornerRadius="3"
                                        Color="White"
                                        Opacity="0.9" />
                                    <BoxView
                                        HeightRequest="4"
                                        CornerRadius="3"
                                        Color="White"
                                        Opacity="0.9" />
                                    <BoxView
                                        HeightRequest="4"
                                        CornerRadius="3"
                                        Color="White"
                                        Opacity="0.9" />
                                </VerticalStackLayout>
                            </Border>

                            <Label
                                Text="🔔"
                                FontSize="42"
                                Rotation="-15"
                                HorizontalOptions="End"
                                VerticalOptions="End"
                                Margin="0,0,2,8" />
                        </Grid>
                    </Grid>

                    <!-- Full Name -->
                    <VerticalStackLayout Spacing="10">
                        <Label
                            Text="Full Name"
                            FontSize="15"
                            FontAttributes="Bold"
                            TextColor="#111827" />

                        <Border
                            HeightRequest="58"
                            BackgroundColor="White"
                            Stroke="#E5E7EB"
                            StrokeThickness="1.5"
                            StrokeShape="RoundRectangle 16"
                            Padding="14,0">

                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Label
                                    Text="👤"
                                    FontSize="20"
                                    Opacity="0.55"
                                    VerticalOptions="Center" />

                                <Entry
                                    x:Name="FullNameEntry"
                                    Grid.Column="1"
                                    Placeholder="Masukkan nama lengkap"
                                    PlaceholderColor="#9CA3AF"
                                    TextColor="#111827"
                                    BackgroundColor="Transparent"
                                    FontSize="15"
                                    VerticalOptions="Center" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Reminder -->
                    <Grid
                        ColumnDefinitions="*,Auto"
                        ColumnSpacing="16"
                        Margin="0,10,0,0">

                        <VerticalStackLayout Spacing="6">
                            <Label
                                Text="Aktifkan pengingat harian?"
                                FontSize="16"
                                FontAttributes="Bold"
                                TextColor="#111827" />

                            <Label
                                Text="Dapatkan pengingat untuk belajar setiap hari."
                                FontSize="13"
                                TextColor="#4B5563" />
                        </VerticalStackLayout>

                        <Switch
                            x:Name="ReminderSwitch"
                            Grid.Column="1"
                            OnColor="#059669"
                            ThumbColor="White"
                            VerticalOptions="Center" />
                    </Grid>

                    <!-- Reminder Time -->
                    <VerticalStackLayout Spacing="10">
                        <Label
                            Text="Waktu Pengingat"
                            FontSize="16"
                            FontAttributes="Bold"
                            TextColor="#111827" />

                        <Border
                            HeightRequest="58"
                            BackgroundColor="White"
                            Stroke="#E5E7EB"
                            StrokeThickness="1.5"
                            StrokeShape="RoundRectangle 16"
                            Padding="16,0">

                            <Grid ColumnDefinitions="*,Auto">
                                <TimePicker
                                    x:Name="ReminderTimePicker"
                                    Time="20:00:00"
                                    TextColor="#111827"
                                    FontSize="15"
                                    FontAttributes="Bold"
                                    BackgroundColor="Transparent"
                                    VerticalOptions="Center" />

                                <Label
                                    Grid.Column="1"
                                    Text="🕘"
                                    FontSize="22"
                                    Opacity="0.6"
                                    VerticalOptions="Center" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <Grid HeightRequest="120" />

                    <Button
                        Text="Simpan &amp; Mulai"
                        BackgroundColor="#059669"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="16"
                        CornerRadius="14"
                        HeightRequest="58"
                        Clicked="OnStartClicked" />

                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>