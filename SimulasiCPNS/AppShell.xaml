<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SimulasiCPNS.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:SimulasiCPNS.Views"
    Title="SimulasiCPNS"
    FlyoutBehavior="Disabled"
    Shell.NavBarIsVisible="False"
    Shell.TabBarBackgroundColor="White"
    Shell.TabBarTitleColor="#E11D48"
    Shell.TabBarForegroundColor="#E11D48"
    Shell.TabBarUnselectedColor="#6B7280">
    
    <ShellContent
        Route="splash"
        Shell.TabBarIsVisible="False"
        ContentTemplate="{DataTemplate views:SplashPage}" />

    <ShellContent
        Route="onboarding"
        Shell.TabBarIsVisible="False"
        ContentTemplate="{DataTemplate views:OnboardingPage}" />

    <!-- Main app -->
    <TabBar Route="main">

        <ShellContent
            Title="Home"
            Route="home"
            Icon="icon_home.svg"
            ContentTemplate="{DataTemplate views:HomePage}" />

        <ShellContent
            Title="Kategori"
            Route="category"
            Icon="icon_category.svg"
            ContentTemplate="{DataTemplate views:CategoryPage}" />

        <ShellContent
            Title="Bookmark"
            Route="bookmark"
            Icon="icon_bookmark.svg"
            ContentTemplate="{DataTemplate views:BookmarkPage}" />

        <ShellContent
            Title="Report"
            Route="report"
            Icon="icon_report.svg"
            ContentTemplate="{DataTemplate views:ReportPage}" />

        <ShellContent
            Title="Setting"
            Route="setting"
            Icon="icon_setting.svg"
            ContentTemplate="{DataTemplate views:SettingPage}" />

    </TabBar>

</Shell>
